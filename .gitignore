# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/
/.claude/
/.vscode/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
*.bak

# env files (allow .env.example template)
.env
.env.local
.env.production
.env.development

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ---- 运行时数据（不应提交到 Git） ----
# SQLite 数据库文件
*.sqlite3
*.db
*.sqlite
# 临时/生成 JSON 数据文件（不影响 package.json / tsconfig.json 等）
tmp_*.json
*_dump*.json
# 日志（*.log 已在 debug 段定义，此处保留以覆盖子目录）
*.dump

# 爬虫采集数据
data/lottery_data/

# API 缓存数据
data/api_data/

# Python 缓存
__pycache__/
*.pyc
