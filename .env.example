# ============================================================
# 六合彩彩票数据管理系统 - 环境变量模板
# 复制此文件为 .env 并修改实际值
# cp .env.example .env
# ============================================================

# PostgreSQL 数据库密码（生产环境务必修改）
POSTGRES_PASSWORD=change_me_in_production

# 站点 ID（多站点模式下的站点标识）
LOTTERY_SITE_ID=1