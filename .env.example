# ============================================================
# 六合彩彩票数据管理系统 - 环境变量模板
# 复制此文件为 .env 并修改实际值
# cp .env.example .env
# ============================================================

# PostgreSQL 数据库密码（生产环境务必修改）
POSTGRES_PASSWORD=change_me_in_production

# 宿主机调试时可选使用；容器内部会由 docker-compose.yml 注入正式 DATABASE_URL
DATABASE_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5432/liuhecai

# 站点 ID（多站点模式下的站点标识）
LOTTERY_SITE_ID=1
